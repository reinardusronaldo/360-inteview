<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Products</title>
  {{ content_for_header }}

  <style>
    :root {
      --page-bg: #edf1f4;
      --card-bg: #f5f5f5;
      --border: #dcdcdc;
      --text: #2f2f2f;
      --muted: #7a7a7a;
      --icon: #7b8794;
      --button-border: #2f2f2f;
      --container: 1180px;
      --radius: 999px;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      background: var(--page-bg);
      color: var(--text);
      line-height: 1.3;
    }

    img {
      display: block;
      max-width: 100%;
      height: auto;
    }

    button,
    input,
    select {
      font: inherit;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    label{
      margin: 0;
    }

    .page {
      padding: 18px 12px 36px;
    }

    .container {
      width: 100%;
      max-width: var(--container);
      margin: 0 auto;
    }

    .listing-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 18px;
      align-items: start;
    }

    .sidebar {
      display: none;
    }

    .content {
      min-width: 0;
    }

    .mobile-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
      font-size: 11px;
    }

    .mobile-topbar__left,
    .mobile-topbar__right {
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
    }

    .mobile-filter-trigger {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
    }

    .result-count {
      color: var(--muted);
      white-space: nowrap;
      font-size: 10px;
    }

    .toolbar {
      display: none;
    }

    .filters {
      display: none;
      margin-top: 20px;
    }

    .filter-group {
      border-top: 1px solid var(--border);
      padding: 12px 0;
    }

    .filter-group:last-child {
      border-bottom: 1px solid var(--border);
    }

    .filter-group__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 11px;
      font-weight: 700;
    }

    .icon-grid,
    .icon-list,
    .icon-filter,
    .icon-sort,
    .icon-plus,
    .icon-eye {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--icon);
      flex-shrink: 0;
    }

    .icon-grid svg,
    .icon-list svg,
    .icon-filter svg,
    .icon-sort svg,
    .icon-plus svg,
    .icon-eye svg {
      width: 14px;
      height: 14px;
      display: block;
    }

    .toolbar__icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      color: #8b949e;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .toolbar__icon svg {
      width: 14px;
      height: 14px;
      display: block;
    }

    .toolbar__icon.is-active,
    .toolbar__icon:hover {
      color: #6f7882;
    }

    .toolbar-sort {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      position: relative;
    }

    .toolbar-sort__icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #8b949e;
    }

    .toolbar-sort__icon svg {
      width: 14px;
      height: 14px;
      display: block;
    }

    .toolbar-sort__label {
      color: #6f7882;
      font-size: 11px;
      line-height: 1;
    }

    .toolbar-sort__select-wrap {
      position: relative;
      display: inline-flex;
      align-items: center;
    }

    .toolbar-sort__select {
      appearance: none;
      -webkit-appearance: none;
      -moz-appearance: none;
      border: 0;
      background: transparent;
      color: #6f7882;
      font-size: 11px;
      line-height: 1;
      padding: 0 16px 0 0;
      cursor: pointer;
      outline: none;
    }

    .toolbar-sort__caret {
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-52%);
      font-size: 10px;
      color: #6f7882;
      pointer-events: none;
    }

    .products {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0;
      border-top: 1px solid var(--border);
      border-left: 1px solid var(--border);
      background: transparent;
    }

    .product-card {
      min-width: 0;
      padding: 10px 10px 12px;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: transparent;
    }

    .product-card__body {
      padding: 0 0 10px;
      min-height: 64px;
    }

    .product-card__title {
      margin: 0 0 3px;
      font-size: 12px;
      line-height: 1.2;
      font-weight: 700;
      letter-spacing: 0;
      word-break: break-word;
    }

    .product-card__meta {
      margin: 0;
      font-size: 10px;
      line-height: 1.28;
      color: var(--muted);
      word-break: break-word;
    }

    .product-card__media {
      position: relative;
      background: var(--card-bg);
      aspect-ratio: 1 / 1;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .product-card__media img {
      width: 72%;
      height: 72%;
      object-fit: contain;
    }

    .product-card__view {
      position: absolute;
      right: 8px;
      bottom: 8px;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: #ffffff;
      box-shadow: 0 0 0 1px rgba(17, 24, 39, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #9aa3ae;
    }

    .pagination-info {
      text-align: center;
      color: var(--muted);
      font-size: 10px;
      margin: 14px 0 10px;
    }

    .load-more-wrap {
      display: flex;
      justify-content: center;
    }

    .load-more {
      appearance: none;
      border: 1px solid var(--button-border);
      background: transparent;
      color: var(--text);
      border-radius: var(--radius);
      height: 30px;
      min-width: 140px;
      padding: 0 18px;
      font-size: 10px;
      cursor: pointer;
    }

    @media (min-width: 768px) {
      .page {
        padding: 28px 20px 40px;
      }

      .listing-grid {
        grid-template-columns: 170px minmax(0, 1fr);
        gap: 26px;
      }

      .sidebar {
        display: block;
      }

      .mobile-topbar {
        display: none;
      }

      .toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 14px;
        font-size: 11px;
      }

      .toolbar__left,
      .toolbar__right {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .toolbar__right {
        color: var(--muted);
      }

      .filters {
        display: block;
      }

      .products {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .product-card {
        padding: 14px 14px 16px;
      }

      .product-card__body {
        min-height: 78px;
        padding-bottom: 12px;
      }

      .product-card__title {
        font-size: 13px;
      }

      .product-card__meta {
        font-size: 11px;
      }

      .product-card__view {
        display: none;
      }

      .pagination-info {
        margin-top: 16px;
      }
    }

    @media (min-width: 1100px) {
      .product-card {
        padding: 16px 14px 18px;
      }

      .product-card__title {
        font-size: 14px;
      }

      .product-card__meta {
        font-size: 12px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <div class="container">
      <div class="listing-grid">
        <aside class="sidebar">
          <div class="filters">
            <div class="filter-group">
              <div class="filter-group__header">
                <span>Category</span>
                <span class="icon-plus" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                  </svg>
                </span>
              </div>
            </div>

            <div class="filter-group">
              <div class="filter-group__header">
                <span>Condition</span>
                <span class="icon-plus" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M12 5V19M5 12H19" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                  </svg>
                </span>
              </div>
            </div>
          </div>
        </aside>

        <section class="content">
          <div class="mobile-topbar">
            <div class="mobile-topbar__left">
              <a href="#" class="mobile-filter-trigger">
                <span class="icon-filter" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M4 7H20M7 12H17M10 17H14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                  </svg>
                </span>
                <span>Filter &amp; Sort</span>
              </a>
            </div>

            <div class="mobile-topbar__right">
              <span class="result-count">1 / 49 Results</span>

              <a href="?view=grid" class="toolbar__icon is-active" aria-label="Grid view">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <rect x="4" y="4" width="7" height="7" rx="1"></rect>
                  <rect x="13" y="4" width="7" height="7" rx="1"></rect>
                  <rect x="4" y="13" width="7" height="7" rx="1"></rect>
                  <rect x="13" y="13" width="7" height="7" rx="1"></rect>
                </svg>
              </a>

              <a href="?view=list" class="toolbar__icon" aria-label="List view">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M6 7H20M6 12H20M6 17H20" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                  <circle cx="4" cy="7" r="1.2" fill="currentColor"/>
                  <circle cx="4" cy="12" r="1.2" fill="currentColor"/>
                  <circle cx="4" cy="17" r="1.2" fill="currentColor"/>
                </svg>
              </a>
            </div>
          </div>

          <div class="toolbar">
            <div class="toolbar__left">
              <span class="result-count">1 / 49 Results</span>
            </div>

            <div class="toolbar__right">
              <a href="?view=grid" class="toolbar__icon is-active" aria-label="Grid view">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <rect x="4" y="4" width="7" height="7" rx="1"></rect>
                  <rect x="13" y="4" width="7" height="7" rx="1"></rect>
                  <rect x="4" y="13" width="7" height="7" rx="1"></rect>
                  <rect x="13" y="13" width="7" height="7" rx="1"></rect>
                </svg>
              </a>

              <a href="?view=list" class="toolbar__icon" aria-label="List view">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M6 7H20M6 12H20M6 17H20" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                  <circle cx="4" cy="7" r="1.2" fill="currentColor"/>
                  <circle cx="4" cy="12" r="1.2" fill="currentColor"/>
                  <circle cx="4" cy="17" r="1.2" fill="currentColor"/>
                </svg>
              </a>

              <form action="" method="get" class="toolbar-sort">
                <span class="toolbar-sort__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M8 6V18M8 18L5.5 15.5M8 18L10.5 15.5M16 6H19M14 10H19M12 14H19M10 18H19" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>

                <label for="SortBy" class="toolbar-sort__label">Sort</label>

                <div class="toolbar-sort__select-wrap">
                  <select id="SortBy" name="sort_by" class="toolbar-sort__select">
                    <option value="alphabetical" selected>Alphabetical</option>
                    <option value="featured">Featured</option>
                    <option value="best-selling">Best selling</option>
                    <option value="price-ascending">Price, low to high</option>
                    <option value="price-descending">Price, high to low</option>
                  </select>
                  <span class="toolbar-sort__caret" aria-hidden="true">▾</span>
                </div>
              </form>
            </div>
          </div>

          {% assign products_data = 
            "Denatured Alcohol 95%|Ethyl Alcohol|120ml , 4L||
            Dolo Paracetamol|Paracetamol|100 x 10s , 50 x 10s||
            Dermasone Cream|Betamethasone|15gm , 100gm||
            Hygin-X Antiseptic Handrub With Moisturiser|Chlorhexidine Gluconate|60ml , 500ml||
            Acetone||
            Proflavine Hemisulphate Lotion|Proflavine Hemisulphate|50ml , 120ml||
            Seldron Cleaning Lotion|Selenium Sulfide Lotion|100ml||
            Hygin-X Surgical Scrub|Chlorhexidine Gluconate|500ml , 4L , 5L (With Dispenser Pump)||
            Paximol 500 Oral Mixture|Paracetamol|100mL , 100mL (With Unit Box) , 3.8 L||
            Biotine Ointment||
            Prodine Antiseptic Solution|Povidone-Iodine|100ml , 120ml , 500ml , 4L||
            Carrington'S 2 Actions||"
            | split: "||"
          %}

          <div class="products">
            {% for item in products_data %}
              {% assign parts = item | split: "|" %}
              <article class="product-card">
                <div class="product-card__body">
                  <h3 class="product-card__title">{{ parts[0] }}</h3>
                  <p class="product-card__meta">
                    {% if parts[1] != blank %}
                      {{ parts[1] }}<br>
                    {% endif %}
                    {% if parts[2] != blank %}
                      {{ parts[2] }}
                    {% endif %}
                  </p>
                </div>

                <div class="product-card__media">
                  <img
                    src="{{ 'placeholder.png' | asset_url }}"
                    alt="{{ parts[0] | escape }}"
                    loading="lazy"
                  >
                  <span class="product-card__view" aria-hidden="true">
                    <span class="icon-eye">
                      <svg viewBox="0 0 24 24" fill="none">
                        <path d="M2.5 12s3.5-5 9.5-5 9.5 5 9.5 5-3.5 5-9.5 5-9.5-5-9.5-5Z" stroke="currentColor" stroke-width="1.4"/>
                        <circle cx="12" cy="12" r="2.7" stroke="currentColor" stroke-width="1.4"/>
                      </svg>
                    </span>
                  </span>
                </div>
              </article>
            {% endfor %}
          </div>

          <p class="pagination-info">Showing 1-12 of 149 Results</p>

          <div class="load-more-wrap">
            <button class="load-more" type="button">Show More Products</button>
          </div>
        </section>
      </div>
    </div>
  </main>
</body>
</html>